<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/current_recording_fragment_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_surface">

    <View
        android:id="@+id/recording_header_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/nav_bar_surface"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/map_view"
        />

    <TextView
        android:id="@+id/current_rec_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/recording_in_progress"
        android:textAlignment="viewStart"
        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
        android:textColor="@color/on_nav_bar_surface"
        app:layout_constraintEnd_toStartOf="@id/more_btn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:paddingTop="6dp"
        />

    <TextView
        android:id="@+id/route_title_tv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:text=""
        android:textAlignment="viewStart"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
        android:textColor="@color/on_nav_bar_surface"
        app:layout_constraintEnd_toEndOf="@id/current_rec_header"
        app:layout_constraintStart_toStartOf="@id/current_rec_header"
        app:layout_constraintTop_toBottomOf="@id/current_rec_header" />

    <ImageButton
        android:id="@+id/more_btn"
        android:alpha=".9"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:padding="4dp"
        android:src="@drawable/ic_more"
        android:elevation="5dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_marginEnd="12dp"
        app:layout_constraintBottom_toTopOf="@+id/map_view"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/on_nav_bar_surface"
        android:contentDescription="More menu button" />

    <FrameLayout
        android:id="@+id/map_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintBottom_toTopOf="@+id/recording_bottom_bar_divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/route_title_tv" />

    <TextView
        android:id="@+id/location_status_chip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_location_status_chip"
        android:elevation="4dp"
        android:maxWidth="280dp"
        android:maxLines="2"
        android:paddingHorizontal="8dp"
        android:paddingVertical="5dp"
        android:text="@string/location_status_waiting"
        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
        android:textColor="@color/md_onSurface"
        app:layout_constraintStart_toStartOf="@id/map_view"
        app:layout_constraintTop_toTopOf="@id/map_view" />

    <View
        android:id="@+id/recording_bottom_bar_divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/md_surfaceVariant"
        app:layout_constraintBottom_toTopOf="@+id/recording_bottom_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/recording_bottom_bar"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:background="@color/md_surface"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/track_point_count_tv"
            style="@style/Widget.Material3.Button.TextButton.Icon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingHorizontal="0dp"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="@color/md_onSurfaceVariant"
            android:textSize="11sp"
            app:backgroundTint="@color/transparent"
            app:icon="@drawable/ic_route"
            app:iconGravity="textTop"
            app:iconPadding="3dp"
            app:iconSize="22dp"
            app:iconTint="@color/md_onSurfaceVariant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/add_wpt_btn"
            style="@style/Widget.Material3.Button.TextButton.Icon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingHorizontal="0dp"
            android:text="@string/append_track_point"
            android:textAllCaps="false"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="@color/md_onSurfaceVariant"
            android:textSize="11sp"
            app:backgroundTint="@color/transparent"
            app:icon="@drawable/ic_add_location"
            app:iconGravity="textTop"
            app:iconPadding="3dp"
            app:iconSize="22dp"
            app:iconTint="@color/md_onSurfaceVariant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/playpause_btn"
            style="@style/Widget.Material3.Button.TextButton.Icon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingHorizontal="0dp"
            android:text="@string/pause_recording"
            android:textAllCaps="false"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="@color/md_onSurfaceVariant"
            android:textSize="11sp"
            app:backgroundTint="@color/transparent"
            app:icon="@drawable/ic_pause"
            app:iconGravity="textTop"
            app:iconPadding="3dp"
            app:iconSize="22dp"
            app:iconTint="@color/md_onSurfaceVariant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/stop_btn"
            style="@style/Widget.Material3.Button.TextButton.Icon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingHorizontal="0dp"
            android:text="@string/stop_recording"
            android:textAllCaps="false"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="@color/md_primary"
            android:textSize="11sp"
            app:backgroundTint="@color/transparent"
            app:icon="@drawable/ic_stop_recording"
            app:iconGravity="textTop"
            app:iconPadding="3dp"
            app:iconSize="22dp"
            app:iconTint="@color/md_primary" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
