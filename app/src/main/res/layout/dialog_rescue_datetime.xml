<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/dialog_horizontal_padding"
    android:paddingTop="2dp"
    android:paddingEnd="@dimen/dialog_horizontal_padding"
    android:paddingBottom="0dp">

    <TextView
        android:id="@+id/rescue_datetime_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:textColor="@color/md_onSurfaceVariant"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/rescue_datetime_picker_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/rescue_datetime_picker_label"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:textColor="@color/md_onSurfaceVariant" />

    <LinearLayout
        android:id="@+id/rescue_datetime_picker_row"
        android:layout_width="match_parent"
        android:layout_height="132dp"
        android:gravity="center"
        android:orientation="horizontal">

        <NumberPicker
            android:id="@+id/rescue_year_picker"
            android:layout_width="0dp"
            android:layout_height="132dp"
            android:layout_weight="1.15" />

        <NumberPicker
            android:id="@+id/rescue_month_picker"
            android:layout_width="0dp"
            android:layout_height="132dp"
            android:layout_weight="0.8" />

        <NumberPicker
            android:id="@+id/rescue_day_picker"
            android:layout_width="0dp"
            android:layout_height="132dp"
            android:layout_weight="0.8" />

        <NumberPicker
            android:id="@+id/rescue_hour_picker"
            android:layout_width="0dp"
            android:layout_height="132dp"
            android:layout_weight="0.8" />

        <NumberPicker
            android:id="@+id/rescue_minute_picker"
            android:layout_width="0dp"
            android:layout_height="132dp"
            android:layout_weight="0.8" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rescue_date_preset_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/rescue_date_preset_row_one"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rescue_preset_yesterday_button"
                style="@style/Widget.Gpx.Button.Compact.Outlined"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:minHeight="40dp"
                android:maxLines="1"
                android:text="@string/rescue_preset_yesterday"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rescue_preset_two_days_button"
                style="@style/Widget.Gpx.Button.Compact.Outlined"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:minHeight="40dp"
                android:maxLines="1"
                android:text="@string/rescue_preset_two_days_ago"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rescue_preset_three_days_button"
                style="@style/Widget.Gpx.Button.Compact.Outlined"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:minHeight="40dp"
                android:maxLines="1"
                android:text="@string/rescue_preset_three_days_ago"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rescue_date_preset_row_two"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rescue_preset_one_week_button"
                style="@style/Widget.Gpx.Button.Compact.Outlined"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:minHeight="40dp"
                android:maxLines="1"
                android:text="@string/rescue_preset_one_week_ago"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rescue_preset_half_month_button"
                style="@style/Widget.Gpx.Button.Compact.Outlined"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:minHeight="40dp"
                android:maxLines="1"
                android:text="@string/rescue_preset_half_month_ago"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rescue_preset_one_month_button"
                style="@style/Widget.Gpx.Button.Compact.Outlined"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:minHeight="40dp"
                android:maxLines="1"
                android:text="@string/rescue_preset_one_month_ago"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rescue_anchor_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/rescue_clear_time_button"
            style="@style/Widget.Gpx.Button.Compact.Outlined"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:maxLines="1"
            android:text="@string/rescue_clear_time" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/rescue_delete_anchor_button"
            style="@style/Widget.Gpx.Button.Compact.Outlined"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:maxLines="1"
            android:text="@string/rescue_delete_anchor"
            android:textColor="@color/md_error" />
    </LinearLayout>
</LinearLayout>
