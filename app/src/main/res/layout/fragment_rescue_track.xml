<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rescue_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_surface">

    <FrameLayout
        android:id="@+id/rescue_map_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/rescue_panel_scroll"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rescue_toolbar" />

    <LinearLayout
        android:id="@+id/rescue_toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/nav_bar_surface"
        android:gravity="center_vertical"
        android:minHeight="64dp"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/rescue_back_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_left_arrow"
            app:tint="@color/on_nav_bar_surface" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/rescue_title_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rescue_track_title"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/on_nav_bar_surface"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rescue_step_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rescue_step_drawing"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/on_nav_bar_surface" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/rescue_previous_step_button"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="88dp"
            android:minHeight="40dp"
            android:text="@string/rescue_previous_step"
            android:textColor="@color/on_nav_bar_surface"
            android:textSize="12sp"
            app:strokeColor="@color/on_nav_bar_surface" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/rescue_panel_scroll"
        android:layout_width="0dp"
        android:layout_height="320dp"
        android:background="@color/md_surface"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/rescue_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/dialog_horizontal_margin"
            android:paddingTop="14dp"
            android:paddingEnd="@dimen/dialog_horizontal_margin"
            android:paddingBottom="18dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/rescue_title_input_layout"
                style="@style/Widget.Material3.TextInputLayout.FilledBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/rescue_title_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/title"
                    android:inputType="text"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:id="@+id/rescue_search_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.FilledBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/rescue_search_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/rescue_search_hint"
                        android:inputType="text"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/rescue_search_button"
                    android:layout_width="88dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/rescue_search" />
            </LinearLayout>

            <TextView
                android:id="@+id/rescue_status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/md_onSurfaceVariant" />

            <LinearLayout
                android:id="@+id/rescue_anchor_summary_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/rescue_anchor_summary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="@color/md_onSurfaceVariant" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/rescue_anchor_sort_button"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="72dp"
                    android:layout_height="40dp"
                    android:minWidth="72dp"
                    android:minHeight="40dp"
                    android:text="@string/rescue_sort" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rescue_anchor_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="true"
                android:overScrollMode="never" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rescue_import_media_button"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/md3_large_button_height"
                android:layout_marginTop="10dp"
                android:text="@string/rescue_import_media" />

            <TextView
                android:id="@+id/rescue_segment_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/md_onSurface" />

            <LinearLayout
                android:id="@+id/rescue_planning_route_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/rescue_planning_segment_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxLines="2"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/md_onSurface" />

                <Spinner
                    android:id="@+id/rescue_mode_spinner"
                    android:layout_width="132dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <RadioGroup
                android:id="@+id/rescue_candidate_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />

            <LinearLayout
                android:id="@+id/rescue_waypoint_summary_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/rescue_waypoint_summary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="@color/md_onSurfaceVariant" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/rescue_waypoint_sort_button"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="72dp"
                    android:layout_height="40dp"
                    android:minWidth="72dp"
                    android:minHeight="40dp"
                    android:text="@string/rescue_sort" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rescue_waypoint_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="true"
                android:overScrollMode="never" />

            <LinearLayout
                android:id="@+id/rescue_generation_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Spinner
                    android:id="@+id/rescue_interval_spinner"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/rescue_generate_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="144dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:minHeight="48dp"
                    android:text="@string/rescue_generate_preview_short"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rescue_segment_navigation_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/rescue_previous_segment_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/md3_large_button_height"
                    android:layout_weight="1"
                    android:text="@string/rescue_previous_segment" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/rescue_next_button"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/md3_large_button_height"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/rescue_next_step" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rescue_save_button"
                android:layout_width="match_parent"
                android:layout_height="@dimen/md3_large_button_height"
                android:layout_marginTop="10dp"
                android:text="@string/rescue_save_route" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
