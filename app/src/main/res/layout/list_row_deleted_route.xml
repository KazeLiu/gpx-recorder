<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingLeft="16dp"
    android:paddingRight="16dp"
    android:paddingTop="@dimen/md3_card_vertical_margin"
    android:paddingBottom="@dimen/md3_card_vertical_margin"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:background="@color/md_surface"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardBackgroundColor="@color/md_errorContainer"
        app:cardCornerRadius="@dimen/md3_card_corner_radius"
        app:cardElevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/deleted_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:minHeight="80dp"
            android:padding="16dp">

        <TextView
            android:id="@+id/deleted_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/undo_message"
            android:textColor="@color/md_onErrorContainer"
            android:text="@string/route_deleted"/>

        <TextView
            android:id="@+id/undo_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/md_error"
            app:layout_constraintTop_toBottomOf="@+id/deleted_message"
            app:layout_constraintBottom_toBottomOf="parent"
            android:text="@string/tap_to_undo"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
