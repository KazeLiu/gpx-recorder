<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:minHeight="48dp"
    android:gravity="center_vertical"
    android:paddingEnd="0dp"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/rescue_waypoint_drag_handle"
        android:layout_width="40dp"
        android:layout_height="48dp"
        android:contentDescription="@string/rescue_waypoint_drag"
        android:gravity="center"
        android:padding="12dp"
        android:src="@drawable/ic_drag_handle"
        android:tint="?attr/colorOnSurfaceVariant" />

    <TextView
        android:id="@+id/rescue_waypoint_index"
        android:layout_width="28dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
        android:textColor="?attr/colorPrimary"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/rescue_waypoint_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/rescue_waypoint_subtext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/rescue_waypoint_delete_button"
        style="@style/Widget.Gpx.Button.Compact.Text"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:minWidth="48dp"
        android:contentDescription="@string/rescue_delete_short"
        android:insetLeft="0dp"
        android:insetRight="0dp"
        android:text=""
        app:icon="@drawable/ic_delete_sweep"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconTint="?attr/colorOnSurfaceVariant" />
</LinearLayout>
