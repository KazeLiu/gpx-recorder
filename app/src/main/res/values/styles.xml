<resources>

    <!-- Base application theme. -->
    <style name="AppTheme.Base" parent="Theme.Material3.DayNight">
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnPrimary">@color/md_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_onPrimaryContainer</item>
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorOnSecondary">@color/md_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_onSecondaryContainer</item>
        <item name="colorTertiary">@color/md_tertiary</item>
        <item name="colorOnTertiary">@color/md_onTertiary</item>
        <item name="colorError">@color/md_error</item>
        <item name="colorOnError">@color/md_onError</item>
        <item name="colorErrorContainer">@color/md_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_onErrorContainer</item>
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_onSurfaceVariant</item>
        <item name="android:colorBackground">@color/md_background</item>
        <item name="colorOutline">@color/md_outline</item>
        <item name="colorControlActivated">@color/md_primary</item>
        <item name="colorControlHighlight">@color/md_primaryContainer</item>
        <item name="android:colorAccent">@color/md_secondary</item>
        <item name="colorAccent">@color/md_secondary</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowBackground">@color/md_background</item>
        <item name="android:navigationBarColor">@color/md_surface</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="AppTheme" parent="AppTheme.Base">
        <item name="gpxButtonTextOnSurface">@color/md_primary</item>
        <item name="gpxButtonTextOnAccent">@color/md_onPrimary</item>
        <item name="gpxRouteLineColor">@color/google_light_blue</item>
        <item name="gpxPreviewPlaceholderColor">@color/google_light_green</item>
        <item name="gpxTrackPointDragColor">@color/md_primary</item>
        <item name="gpxTrackPointInsertColor">@color/md_secondary</item>
        <item name="gpxTrackPointIconOnColor">@color/md_onSecondary</item>
        <item name="gpxLocationStatusChipSurface">@color/location_status_chip_surface</item>
        <item name="gpxSurfaceContainer">@color/md_surfaceContainer</item>
        <item name="gpxNavBarSurface">@color/nav_bar_surface</item>
        <item name="gpxOnNavBarSurface">@color/on_nav_bar_surface</item>
        <item name="gpxOnNavBarSurfaceSecondary">@color/on_nav_bar_surface_secondary</item>
        <item name="gpxLargeButtonSurface">@color/large_button_surface</item>
        <item name="gpxOnLargeButtonSurface">@color/on_large_button_surface</item>
    </style>

    <style name="AppTheme.Blue" parent="AppTheme.Base">
        <item name="colorPrimary">@color/blue_md_primary</item>
        <item name="colorOnPrimary">@color/blue_md_onPrimary</item>
        <item name="colorPrimaryContainer">@color/blue_md_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/blue_md_onPrimaryContainer</item>
        <item name="colorSecondary">@color/blue_md_secondary</item>
        <item name="colorOnSecondary">@color/blue_md_onSecondary</item>
        <item name="colorSecondaryContainer">@color/blue_md_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/blue_md_onSecondaryContainer</item>
        <item name="colorTertiary">@color/blue_md_tertiary</item>
        <item name="colorOnTertiary">@color/blue_md_onTertiary</item>
        <item name="colorError">@color/blue_md_error</item>
        <item name="colorOnError">@color/blue_md_onError</item>
        <item name="colorErrorContainer">@color/blue_md_errorContainer</item>
        <item name="colorOnErrorContainer">@color/blue_md_onErrorContainer</item>
        <item name="colorSurface">@color/blue_md_surface</item>
        <item name="colorOnSurface">@color/blue_md_onSurface</item>
        <item name="colorSurfaceVariant">@color/blue_md_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/blue_md_onSurfaceVariant</item>
        <item name="android:colorBackground">@color/blue_md_background</item>
        <item name="colorOutline">@color/blue_md_outline</item>
        <item name="colorControlActivated">@color/blue_md_primary</item>
        <item name="colorControlHighlight">@color/blue_md_primaryContainer</item>
        <item name="android:colorAccent">@color/blue_md_secondary</item>
        <item name="colorAccent">@color/blue_md_secondary</item>
        <item name="android:windowBackground">@color/blue_md_background</item>
        <item name="android:navigationBarColor">@color/blue_md_surface</item>
        <item name="gpxButtonTextOnSurface">@color/blue_md_primary</item>
        <item name="gpxButtonTextOnAccent">@color/blue_md_onPrimary</item>
        <item name="gpxRouteLineColor">@color/blue_route_line</item>
        <item name="gpxPreviewPlaceholderColor">@color/blue_preview_placeholder</item>
        <item name="gpxTrackPointDragColor">@color/blue_md_primary</item>
        <item name="gpxTrackPointInsertColor">@color/blue_md_secondary</item>
        <item name="gpxTrackPointIconOnColor">@color/blue_md_onSecondary</item>
        <item name="gpxLocationStatusChipSurface">@color/blue_location_status_chip_surface</item>
        <item name="gpxSurfaceContainer">@color/blue_md_surfaceContainer</item>
        <item name="gpxNavBarSurface">@color/blue_nav_bar_surface</item>
        <item name="gpxOnNavBarSurface">@color/blue_on_nav_bar_surface</item>
        <item name="gpxOnNavBarSurfaceSecondary">@color/blue_on_nav_bar_surface_secondary</item>
        <item name="gpxLargeButtonSurface">@color/blue_large_button_surface</item>
        <item name="gpxOnLargeButtonSurface">@color/blue_on_large_button_surface</item>
    </style>

    <style name="Theme.GpxRecorder.NoActionBarDialog" parent="@style/Theme.Material3.DayNight.Dialog.Alert">
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnPrimary">@color/md_onPrimary</item>
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_onSurfaceVariant</item>
        <item name="android:colorBackground">@color/md_background</item>
        <item name="colorOutline">@color/md_outline</item>
        <item name="android:windowBackground">@color/md_background</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="TextAppearance.Gpx.CompactButton" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Gpx.CompactLargeButton" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Gpx.CompactFieldText" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">15sp</item>
    </style>

    <style name="TextAppearance.Gpx.CompactFieldHint" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Widget.Gpx.Button.Compact" parent="Widget.Material3.Button">
        <item name="android:minWidth">@dimen/md3_compact_button_min_width</item>
        <item name="android:minHeight">@dimen/md3_compact_button_height</item>
        <item name="android:paddingStart">@dimen/md3_compact_button_horizontal_padding</item>
        <item name="android:paddingEnd">@dimen/md3_compact_button_horizontal_padding</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAppearance">@style/TextAppearance.Gpx.CompactButton</item>
    </style>

    <style name="Widget.Gpx.Button.Compact.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minWidth">@dimen/md3_compact_button_min_width</item>
        <item name="android:minHeight">@dimen/md3_compact_button_height</item>
        <item name="android:paddingStart">@dimen/md3_compact_button_horizontal_padding</item>
        <item name="android:paddingEnd">@dimen/md3_compact_button_horizontal_padding</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAppearance">@style/TextAppearance.Gpx.CompactButton</item>
    </style>

    <style name="Widget.Gpx.Button.Compact.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:minWidth">@dimen/md3_compact_button_min_width</item>
        <item name="android:minHeight">@dimen/md3_compact_button_height</item>
        <item name="android:paddingStart">@dimen/md3_compact_text_button_horizontal_padding</item>
        <item name="android:paddingEnd">@dimen/md3_compact_text_button_horizontal_padding</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAppearance">@style/TextAppearance.Gpx.CompactButton</item>
    </style>

    <style name="Widget.Gpx.Button.Compact.Large" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/md3_large_button_height</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAppearance">@style/TextAppearance.Gpx.CompactLargeButton</item>
    </style>

    <style name="Widget.Gpx.TextInputLayout.Compact.Filled" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="hintTextAppearance">@style/TextAppearance.Gpx.CompactFieldHint</item>
        <item name="helperTextTextAppearance">@style/TextAppearance.Gpx.CompactFieldHint</item>
        <item name="errorTextAppearance">@style/TextAppearance.Gpx.CompactFieldHint</item>
    </style>

    <style name="Widget.Gpx.TextInputLayout.Compact.Dropdown" parent="Widget.Material3.TextInputLayout.FilledBox.ExposedDropdownMenu">
        <item name="hintTextAppearance">@style/TextAppearance.Gpx.CompactFieldHint</item>
        <item name="helperTextTextAppearance">@style/TextAppearance.Gpx.CompactFieldHint</item>
        <item name="errorTextAppearance">@style/TextAppearance.Gpx.CompactFieldHint</item>
    </style>

    <style name="GpxCompactTextInputEditText">
        <item name="android:minHeight">@dimen/md3_compact_input_min_height</item>
        <item name="android:paddingTop">@dimen/md3_compact_input_padding_top</item>
        <item name="android:paddingBottom">@dimen/md3_compact_input_padding_bottom</item>
        <item name="android:textAppearance">@style/TextAppearance.Gpx.CompactFieldText</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppTheme.Blue.NoActionBar" parent="AppTheme.Blue">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar"/>

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.Material3.Light"/>

    <style name="Theme.GpxRecorder.ExternalActionBar" parent="Theme.Material3.DayNight">
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnPrimary">@color/md_onPrimary</item>
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_onSurface</item>
        <item name="android:windowBackground">@color/md_background</item>
    </style>

</resources>
